/* components/qiuqiu/qiuqiu.wxss */
.qiuqiu-wrap { display: flex; flex-direction: column; align-items: center; }
.qiuqiu { transition: transform 0.3s; }
.qiuqiu-face { line-height: 1; }

.sm .qiuqiu-face { font-size: 60rpx; }
.md .qiuqiu-face { font-size: 140rpx; }
.lg .qiuqiu-face { font-size: 200rpx; }

.qiuqiu-bubble {
  background: #fff; border-radius: 24rpx; padding: 12rpx 20rpx;
  margin-top: 12rpx; font-size: 26rpx; color: #3D3D3D;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08); max-width: 400rpx;
  text-align: center;
}

/* 动画 */
.anim-jump { animation: q-jump 0.6s ease; }
.anim-wave { animation: q-wave 0.5s ease; }
.anim-spin { animation: q-spin 0.6s ease; }
.anim-flip { animation: q-flip 0.6s ease; }
.anim-yawn { animation: q-yawn 0.8s ease; }

@keyframes q-jump { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-30rpx)} }
@keyframes q-wave { 0%,100%{transform:rotate(0)} 25%{transform:rotate(-15deg)} 75%{transform:rotate(15deg)} }
@keyframes q-spin { 0%{transform:rotate(0)} 100%{transform:rotate(360deg)} }
@keyframes q-flip { 0%{transform:scaleX(1)} 50%{transform:scaleX(0)} 100%{transform:scaleX(1)} }
@keyframes q-yawn { 0%,100%{transform:scale(1)} 50%{transform:scale(1.1)} }
