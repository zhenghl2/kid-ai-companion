.section-title { font-size:34rpx; font-weight:700; margin-bottom:24rpx; text-align:center }
.sticker-grid { display:grid; grid-template-columns:1fr 1fr 1fr; gap:20rpx }
.sticker { text-align:center; padding:24rpx 12rpx; border-radius:24rpx; background:#fff; box-shadow:0 4rpx 12rpx rgba(0,0,0,0.06) }
.sticker.locked { opacity:0.5; background:#F5F5F5 }
.sticker.unlocked { border:2rpx solid #FFD43B }
.sticker-icon { font-size:48rpx; margin-bottom:8rpx }
.sticker-name { font-size:24rpx; font-weight:600; margin-bottom:4rpx }
.sticker-cond { font-size:20rpx; color:#999 }
