.play-header { display:flex; align-items:center; gap:16rpx; margin-bottom:24rpx }
.progress-wrap { flex:1; display:flex; align-items:center; gap:12rpx }
.progress-bar { flex:1; height:12rpx; background:#F0F0F0; border-radius:6rpx; overflow:hidden }
.progress-fill { height:100%; background:#FF6B6B; border-radius:6rpx; transition:width 0.5s }
.progress-text { font-size:24rpx; color:#999; min-width:60rpx }
.exit-btn { width:48rpx; height:48rpx; display:flex; align-items:center; justify-content:center; font-size:28rpx; color:#ccc; border-radius:50%; background:#f5f5f5 }

/* 教学卡片 */
.teach-card { text-align:center; padding:60rpx 32rpx; background:linear-gradient(135deg,#FFF8F0,#FFF0E0) }
.teach-emoji { font-size:80rpx; margin-bottom:16rpx }
.teach-main { font-size:72rpx; font-weight:700; color:#3D3D3D; margin-bottom:8rpx; line-height:1.2 }
.teach-sub { font-size:28rpx; color:#999; margin-bottom:12rpx }
.teach-hint { font-size:24rpx; color:#FF6B6B; animation:pulse 1.5s infinite }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.5} }

.story-card { text-align:center; padding:40rpx 32rpx }
.story-text { font-size:38rpx; line-height:1.6; font-weight:500 }
.tts-replay { display:inline-block; margin-top:12rpx; padding:6rpx 16rpx; background:#f0f0f0; border-radius:16rpx; font-size:24rpx; color:#999 }

.options-grid { display:grid; grid-template-columns:1fr 1fr; gap:20rpx; margin-top:24rpx }
.option-btn { background:#fff; border-radius:48rpx; padding:36rpx 20rpx; text-align:center; font-size:34rpx; font-weight:600; box-shadow:0 4rpx 16rpx rgba(0,0,0,0.06); min-height:120rpx; display:flex; align-items:center; justify-content:center }
.option-btn:active { transform:scale(0.95) }
.option-btn.correct { background:#E8F8E8; border:3rpx solid #51CF66; color:#51CF66 }
.option-btn.wrong { background:#FFF0F0; border:3rpx solid #FFCDD2; color:#EF5350 }

.feedback-area { text-align:center; padding:32rpx 0 }
.feedback-text { font-size:36rpx; font-weight:600; margin-bottom:16rpx }
.feedback-text.correct { color:#51CF66 }
.feedback-text.gentle { color:#FF9800 }

.recovery-card { text-align:center; background:#FFF8E1; padding:32rpx }
.recovery-icon { font-size:64rpx }
.recovery-title { font-size:32rpx; font-weight:600; color:#FF9800; margin:8rpx 0 }
.recovery-text { font-size:26rpx; color:#666 }

.finish-icon { font-size:80rpx; margin-bottom:16rpx }
.finish-stars { font-size:40rpx; margin-bottom:12rpx }
.finish-msg { font-size:28rpx; color:#666 }
