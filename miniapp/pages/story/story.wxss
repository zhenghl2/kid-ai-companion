.story-content { padding:80rpx 40rpx; text-align:center }
.story-moon { font-size:80rpx; margin-bottom:32rpx }
.story-title { font-size:40rpx; font-weight:700; color:#FFD43B; margin-bottom:48rpx }
.story-p { font-size:34rpx; color:rgba(255,255,255,0.85); line-height:2; margin-bottom:24rpx; text-shadow:0 0 20rpx rgba(255,255,255,0.3) }
.story-end { font-size:48rpx; color:rgba(255,255,255,0.4); margin-top:60rpx; letter-spacing:8rpx; animation:pulse 2s infinite }
.story-footer { position:fixed; bottom:60rpx; left:0; right:0; display:flex; justify-content:center }
@keyframes pulse { 0%,100%{opacity:0.3} 50%{opacity:0.8} }
