.onboard-page { display:flex; flex-direction:column; justify-content:center; min-height:100vh }
.onboard-header { text-align:center; margin-bottom:48rpx }
.onboard-icon { font-size:120rpx; margin-bottom:16rpx }
.onboard-title { font-size:40rpx; font-weight:700; margin-bottom:8rpx }
.onboard-sub { font-size:28rpx; color:#999 }
.form-group { margin-bottom:28rpx }
.form-label { font-size:28rpx; color:#666; margin-bottom:10rpx }
.form-input { width:100%; padding:24rpx 20rpx; border:2rpx solid #E0E0E0; border-radius:24rpx; font-size:32rpx; background:#FAFAFA; box-sizing:border-box; line-height:1.4; height:auto; min-height:80rpx }
.form-input.picker { color:#999 }
.form-hint { font-size:24rpx; color:#FF6B6B; margin-top:8rpx; padding-left:4rpx }
